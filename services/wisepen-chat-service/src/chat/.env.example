# =============================================================================
# env 样例
# -----------------------------------------------------------------------------
# 此 env 为 bootstrap 阶段（连 Nacos 之前）必须就位的最小环境变量集合
# 业务字段由 Nacos 配置中心注入
#
# 用法：
#   cp .env.example .env
#   按需修改相关变量
# =============================================================================

# Nacos 接入
NACOS_SERVER_ADDR=localhost:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# Profile
PROFILE=dev

# 以下字段都有合理默认，注释即用默认
# 服务监听（uvicorn + Nacos 服务注册）容器化时用 0.0.0.0
# SERVICE_HOST=127.0.0.1
# SERVICE_PORT=9200

# 早期日志级别（Nacos 拉取之前生效，之后仍作用于 LiteLLM 等组件）
# LOG_LEVEL=INFO

# Nacos 命名空间 / 分组（默认 public 命名空间 + DEFAULT_GROUP）
# NACOS_NAMESPACE_ID=
# NACOS_GROUP=DEFAULT_GROUP

# 注册到 Nacos 时的本机 IP（可选）
# 留空时 nacos_client._resolve_host() 用 socket.gethostname自动选择，容器 / 多网卡场景下显式指定更稳
# NACOS_REGISTER_IP=
